{
  "name": "lift-operator",
  "version": "0.1.0",
  "private": true,
  "description": "Local development and automated testing tools for Lift Operator.",
  "scripts": {
    "serve": "node tests/test-server.js",
    "test": "npm run test:syntax && npm run test:config && npm run balance:check && npm run test:economy && npm run balance:report:check && playwright test",
    "test:syntax": "node scripts/check-syntax.js",
    "test:config": "node scripts/validate-config.js",
    "balance:generate": "node scripts/generate-balance.js",
    "balance:check": "node scripts/generate-balance.js --check",
    "test:economy": "node scripts/simulate-economy.js",
    "balance:matrix": "node scripts/run-balance-matrix.js",
    "balance:experiment:early": "node scripts/run-early-balance-experiments.js",
    "balance:report:check": "node scripts/validate-balance-report.js",
    "test:lifecycle": "playwright test tests/lifecycle-correctness.spec.js",
    "test:e2e": "playwright test tests/auto-pilot.spec.js",
    "test:e2e:report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "1.55.1",
    "lz-string": "1.5.0"
  }
}
