{
  "name": "lift-operator",
  "version": "0.1.0",
  "private": true,
  "description": "Local development and automated testing tools for Lift Operator.",
  "scripts": {
    "serve": "node tests/test-server.js",
    "test": "npm run test:full",
    "test:syntax": "node scripts/check-syntax.js",
    "docs:check": "node scripts/check-docs.js",
    "test:config": "node scripts/validate-config.js",
    "balance:generate": "node scripts/generate-balance.js",
    "balance:check": "node scripts/generate-balance.js --check",
    "test:economy": "node scripts/simulate-economy.js",
    "balance:matrix": "node scripts/run-balance-matrix.js",
    "balance:experiment:early": "node scripts/run-early-balance-experiments.js",
    "balance:envelope": "node scripts/run-campaign-envelope.js",
    "balance:report:check": "node scripts/validate-balance-report.js",
    "test:lifecycle": "playwright test tests/lifecycle-correctness.spec.js",
    "test:e2e": "playwright test tests/auto-pilot.spec.js",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:mechanics": "playwright test tests/lifecycle-correctness.spec.js --grep \"patience|boarding|VIP|Gym|jam|stink|rooftop|Musak|Group Think|Open Plan\"",
    "test:integration": "playwright test tests/integration",
    "test:smoke": "npm run test:syntax && npm run docs:check && npm run test:config && npm run test:utf8 && playwright test tests/lifecycle-correctness.spec.js --grep \"retry|canonical|countdown|automation bridge\"",
    "test:full": "npm run test:syntax && npm run docs:check && npm run test:config && npm run balance:check && npm run test:economy && npm run balance:report:check && npm run test:utf8 && npm run test:unit && npm run test:mechanics && npm run test:integration && playwright test",
    "test:utf8": "node scripts/validate-utf8.js",
    "sim:matrix": "node scripts/run-simulation-batch.js",
    "sim:replay": "node scripts/replay-simulation.js",
    "sim:repro": "node scripts/validate-reproducibility.js",
    "balance:summarize": "node scripts/summarize-balance-run.js",
    "balance:search": "node scripts/search-balance.js",
    "balance:gate": "node scripts/balance-gate.js",
    "balance:robustness": "node scripts/balance-robustness.js",
    "balance:promote": "node scripts/balance-promote.js",
    "human:protocol": "node scripts/validate-human-protocol.js",
    "audit:completion": "node scripts/audit-completion.js",
    "balance:search:late": "node scripts/search-late-balance.js",
    "economy:search": "node scripts/economy-search.js",
    "test:e2e:report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "1.55.1",
    "lz-string": "1.5.0"
  }
}
